<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN CÁ NHÂN"
            android:textColor="#FF0000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>


        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="Avatar"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerCrop"
            android:background="@android:drawable/picture_frame"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhấn để chọn ảnh"
            android:textSize="12sp"
            android:textColor="#03A9F4"
            android:layout_marginBottom="16dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Họ tên"
                android:textSize="16sp"
                android:textColor="#555555"/>

            <EditText
                android:id="@+id/edtHoTen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập họ tên"
                android:inputType="textPersonName"
                android:backgroundTint="#00BFA5"/>
        </LinearLayout>

        // Dòng Điện thoại
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Điện thoại"
                android:textSize="16sp"
                android:textColor="#555555"/>

            <EditText
                android:id="@+id/edtDienThoai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập số điện thoại"
                android:inputType="phone"/>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Giới tính"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <Switch
                android:id="@+id/swGioiTinh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00BFA5"
                android:trackTint="#A7FFEB"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nam"
                android:textSize="16sp"
                android:textColor="#555555"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        //Thanh tiêu đề Bằng cấp
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#03A9F4"
            android:text="Bằng cấp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="6dp"
            android:layout_marginBottom="12dp"/>
    
        // Nhóm RadioButton Bằng cấp 
        <RadioGroup
            android:id="@+id/rgBangCap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbCaoDang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cao đẳng"
                android:layout_marginEnd="10dp"/>

            <RadioButton
                android:id="@+id/rbDaiHoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đại học"
                android:layout_marginEnd="10dp"/>

            <RadioButton
                android:id="@+id/rbCaoHoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cao học"/>
        </RadioGroup>

        //Thanh tiêu đề Sở thích
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#03A9F4"
            android:text="Sở thích"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:padding="6dp"
            android:layout_marginBottom="12dp"/>

        // Các Checkbox Sở thích
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <CheckBox
                android:id="@+id/cbBongDa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bóng đá"/>

            <CheckBox
                android:id="@+id/cbNgheNhac"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nghe nhạc"/>

            <CheckBox
                android:id="@+id/cbXemPhim"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Xem phim"/>

            <CheckBox
                android:id="@+id/cbDuLich"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Du lịch"/>
        </LinearLayout>

        // Hai nút bấm
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <Button
                android:id="@+id/btnXacNhan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XÁC NHẬN"
                android:backgroundTint="#03A9F4"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="20dp"/>

            <Button
                android:id="@+id/btnHuy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HỦY"
                android:backgroundTint="#03A9F4"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        // Vùng hiển thị kết quả
        <TextView
            android:id="@+id/tvKetQua"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hiện kết quả"
            android:textSize="18sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</ScrollView>